# App
APP_DEPLOYMENT_MODE=single_company
APP_DATABASE_MODE=memory
PUBLIC_BASE_URL=http://localhost:3000
ALLOW_DEV_AUTH=true
SESSION_COOKIE_NAME=agent_platform_session
AGENT_MAX_TOOL_ITERATIONS=4

# Single-company mode
SINGLE_COMPANY_TENANT_SLUG=acme
SINGLE_COMPANY_TENANT_NAME=Acme Internal AI
SINGLE_COMPANY_PRIMARY_DOMAIN=acme.example
SINGLE_COMPANY_DEFAULT_RETENTION=retained
SINGLE_COMPANY_ALLOW_USER_BYO_PROVIDER=false
SINGLE_COMPANY_DEFAULT_PROVIDER_ID=mock
SINGLE_COMPANY_DEFAULT_MODEL_ID=mock-chat

# Multi-tenant seed defaults
MULTI_TENANT_DEFAULT_TENANT_SLUG=demo
MULTI_TENANT_DEFAULT_TENANT_NAME=Demo Tenant

# Local development auth. Do not enable in production.
DEV_AUTH_EMAIL=admin@acme.example
DEV_AUTH_DISPLAY_NAME=Development Admin
DEV_AUTH_ROLE=company_admin

# Database and local services
DATABASE_URL=postgresql://agent:agent@localhost:5432/agent_platform
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=agent-platform
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio-password

# KMS and encryption
KMS_PROVIDER=local
LOCAL_KMS_MASTER_KEY_BASE64=REPLACE_WITH_32_RANDOM_BYTES_BASE64
PRODUCTION_KMS_PROVIDER=vault_transit
VAULT_ADDR=https://vault.example
VAULT_TRANSIT_KEY=agent-platform-content
VAULT_TOKEN=replace-with-vault-token

# Provider defaults
DEFAULT_PROVIDER_ID=mock
DEFAULT_MODEL_ID=mock-chat
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY_REF=secret://tenant/openai

# OIDC / Microsoft Entra placeholders
OIDC_ENABLED=false
OIDC_PROVIDER_TYPE=microsoft_entra
OIDC_ISSUER_URL=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0
OIDC_CLIENT_ID=replace-me
OIDC_CLIENT_SECRET_REF=env://OIDC_CLIENT_SECRET
OIDC_CLIENT_SECRET=replace-me
OIDC_ALLOWED_EMAIL_DOMAINS=acme.example
OIDC_CLAIM_MAPPING_JSON={"subject":"sub","email":"email","displayName":"name","groups":"groups","roles":"roles"}
