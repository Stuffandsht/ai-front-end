{
  "name": "ai-agent-chat-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable multi-tenant and single-company AI agent chat control plane.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @agent-platform/web",
    "build": "npm run typecheck && npm run build --workspace @agent-platform/web",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern eslint.config.js --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit tests/security",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:headless": "vitest run tests/e2e",
    "test:all": "npm run lint && npm run typecheck && npm run test && npm run test:integration && npm run test:e2e:headless && npm run test:e2e",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "tsx scripts/db-seed.ts",
    "compose:check": "node scripts/compose-check.mjs"
  },
  "dependencies": {
    "@next/env": "^15.3.5",
    "next": "^15.3.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.30.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "postcss": "^8.5.16"
  }
}
